---
interface Props {
	duration: string;
}

const { duration } = Astro.props;
---

<li class="relative pl-8 sm:pl-10">
	<span class="absolute left-0 top-1.5 h-2 w-2 rounded-full bg-indigo-400 ring-4 ring-black" aria-hidden="true"></span>

	<div class="z-10 mb-1 text-xs font-semibold uppercase tracking-wide text-neutral-500" aria-label={duration}>
		{duration}
	</div>

	<slot />
</li>
