---
interface Props {
	label: string;
	showDesktopHeading?: boolean;
}

const { label, showDesktopHeading = true } = Astro.props;
---

<div
	class="sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
>
	<h2 class="text-sm font-bold uppercase tracking-widest text-neutral-200 lg:sr-only">{label}</h2>
</div>

{
	showDesktopHeading && (
		<h2 class="mb-4 hidden text-sm font-bold uppercase tracking-widest text-neutral-200 lg:block">{label}</h2>
	)
}
